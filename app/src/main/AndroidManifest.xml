<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.HappyMinds">

        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.HappyMinds.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".MainActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity android:name=".ui.auth.LoginActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity android:name=".ui.auth.RegisterActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity android:name=".ui.auth.SetupProfileActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity android:name=".ui.auth.VolunteerRegistrationActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity android:name=".ui.auth.AdminLoginActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity android:name=".ui.admin.AdminDashboardActivity"
            android:exported="false" />

        <activity android:name=".ui.learn.LessonPlayerActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

    </application>

</manifest>
