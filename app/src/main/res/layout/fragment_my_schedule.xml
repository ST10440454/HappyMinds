<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_cream">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_orange_gradient"
        android:paddingHorizontal="20dp"
        android:paddingTop="52dp"
        android:paddingBottom="24dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_chevron_right"
            android:rotation="180"
            android:contentDescription="Back"
            android:layout_marginEnd="12dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="My Schedule"
            android:textColor="@color/text_white"
            android:textSize="22sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btnAddSchedule"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_calendar"
            android:contentDescription="Add"
            android:padding="4dp" />
    </LinearLayout>

    <!-- Day selector -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="16dp"
        android:paddingVertical="16dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView android:id="@+id/dayMon"
                android:layout_width="56dp" android:layout_height="56dp"
                android:text="Mon\n5" android:gravity="center" android:textSize="13sp"
                android:textColor="@color/text_white" android:textStyle="bold"
                android:background="@drawable/bg_button_orange" android:layout_marginEnd="8dp"/>

            <TextView android:id="@+id/dayTue"
                android:layout_width="56dp" android:layout_height="56dp"
                android:text="Tue\n6" android:gravity="center" android:textSize="13sp"
                android:textColor="@color/text_medium"
                android:background="@drawable/card_background" android:layout_marginEnd="8dp"/>

            <TextView android:id="@+id/dayWed"
                android:layout_width="56dp" android:layout_height="56dp"
                android:text="Wed\n7" android:gravity="center" android:textSize="13sp"
                android:textColor="@color/text_medium"
                android:background="@drawable/card_background" android:layout_marginEnd="8dp"/>

            <TextView android:id="@+id/dayThu"
                android:layout_width="56dp" android:layout_height="56dp"
                android:text="Thu\n8" android:gravity="center" android:textSize="13sp"
                android:textColor="@color/text_medium"
                android:background="@drawable/card_background" android:layout_marginEnd="8dp"/>

            <TextView android:id="@+id/dayFri"
                android:layout_width="56dp" android:layout_height="56dp"
                android:text="Fri\n9" android:gravity="center" android:textSize="13sp"
                android:textColor="@color/text_medium"
                android:background="@drawable/card_background" android:layout_marginEnd="8dp"/>

            <TextView android:id="@+id/daySat"
                android:layout_width="56dp" android:layout_height="56dp"
                android:text="Sat\n10" android:gravity="center" android:textSize="13sp"
                android:textColor="@color/text_medium"
                android:background="@drawable/card_background" android:layout_marginEnd="8dp"/>

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Schedule list -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- Time slot 1 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="16dp">
                <LinearLayout android:layout_width="48dp" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="15:00" android:textSize="13sp" android:textColor="@color/text_medium"
                        android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="AM" android:textSize="11sp" android:textColor="@color/text_light"/>
                </LinearLayout>
                <View android:layout_width="2dp" android:layout_height="match_parent"
                    android:background="@color/orange_primary" android:layout_marginHorizontal="12dp"/>
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    app:cardCornerRadius="12dp" app:cardElevation="2dp" app:cardBackgroundColor="@color/bg_light_orange">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Mathematics" android:textSize="15sp" android:textStyle="bold"
                            android:textColor="@color/text_dark"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Fractions &amp; Decimals · 45 min" android:textSize="13sp"
                            android:textColor="@color/text_light" android:paddingTop="2dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Time slot 2 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="16dp">
                <LinearLayout android:layout_width="48dp" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="15:45" android:textSize="13sp" android:textColor="@color/text_medium"
                        android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="AM" android:textSize="11sp" android:textColor="@color/text_light"/>
                </LinearLayout>
                <View android:layout_width="2dp" android:layout_height="match_parent"
                    android:background="@color/teal_primary" android:layout_marginHorizontal="12dp"/>
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    app:cardCornerRadius="12dp" app:cardElevation="2dp" app:cardBackgroundColor="@color/bg_light_teal">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="English Reading" android:textSize="15sp" android:textStyle="bold"
                            android:textColor="@color/text_dark"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Story Comprehension · 45 min" android:textSize="13sp"
                            android:textColor="@color/text_light" android:paddingTop="2dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Time slot 3 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="16dp">
                <LinearLayout android:layout_width="48dp" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="16:30" android:textSize="13sp" android:textColor="@color/text_medium"
                        android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="PM" android:textSize="11sp" android:textColor="@color/text_light"/>
                </LinearLayout>
                <View android:layout_width="2dp" android:layout_height="match_parent"
                    android:background="@color/orange_primary" android:layout_marginHorizontal="12dp"/>
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    app:cardCornerRadius="12dp" app:cardElevation="2dp" app:cardBackgroundColor="@color/bg_light_orange">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Science" android:textSize="15sp" android:textStyle="bold"
                            android:textColor="@color/text_dark"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="The Solar System · 45 min" android:textSize="13sp"
                            android:textColor="@color/text_light" android:paddingTop="2dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Time slot 4 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="16dp">
                <LinearLayout android:layout_width="48dp" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="17:15" android:textSize="13sp" android:textColor="@color/text_medium"
                        android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="PM" android:textSize="11sp" android:textColor="@color/text_light"/>
                </LinearLayout>
                <View android:layout_width="2dp" android:layout_height="match_parent"
                    android:background="@color/teal_primary" android:layout_marginHorizontal="12dp"/>
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    app:cardCornerRadius="12dp" app:cardElevation="2dp" app:cardBackgroundColor="@color/bg_light_teal">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Social Studies" android:textSize="15sp" android:textStyle="bold"
                            android:textColor="@color/text_dark"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="African History · 45 min" android:textSize="13sp"
                            android:textColor="@color/text_light" android:paddingTop="2dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
