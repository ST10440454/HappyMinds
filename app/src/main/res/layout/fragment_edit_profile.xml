<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_cream">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_orange_gradient"
            android:paddingHorizontal="20dp"
            android:paddingTop="52dp"
            android:paddingBottom="24dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_chevron_right"
                android:rotation="180"
                android:contentDescription="Back"
                android:layout_marginEnd="12dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Edit Profile"
                android:textColor="@color/text_white"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Avatar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingVertical="28dp">

            <TextView
                android:id="@+id/tvAvatarInitials"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/bg_avatar_circle"
                android:text="TK"
                android:textColor="@color/text_white"
                android:textSize="28sp"
                android:textStyle="bold"
                android:gravity="center" />

            <TextView
                android:id="@+id/tvChangePhoto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Change Photo"
                android:textColor="@color/text_orange"
                android:textSize="14sp"
                android:textStyle="bold"
                android:paddingTop="10dp" />
        </LinearLayout>

        <!-- Form Fields -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp">

            <!-- Child's Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Child's Full Name"
                android:textColor="@color/text_medium"
                android:textSize="13sp"
                android:textStyle="bold"
                android:paddingBottom="6dp" />

            <EditText
                android:id="@+id/etChildName"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Enter child's name"
                android:text="Thato Khumalo"
                android:textColor="@color/text_dark"
                android:textSize="15sp"
                android:background="@drawable/card_background"
                android:paddingHorizontal="16dp"
                android:inputType="textPersonName"
                android:layout_marginBottom="16dp" />

            <!-- Age -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Age"
                android:textColor="@color/text_medium"
                android:textSize="13sp"
                android:textStyle="bold"
                android:paddingBottom="6dp" />

            <EditText
                android:id="@+id/etAge"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Your age"
                android:text="10"
                android:textColor="@color/text_dark"
                android:textSize="15sp"
                android:background="@drawable/card_background"
                android:paddingHorizontal="16dp"
                android:inputType="number"
                android:layout_marginBottom="16dp" />

            <!-- Grade -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Grade"
                android:textColor="@color/text_medium"
                android:textSize="13sp"
                android:textStyle="bold"
                android:paddingBottom="6dp" />

            <EditText
                android:id="@+id/etGrade"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Your grade"
                android:text="4"
                android:textColor="@color/text_dark"
                android:textSize="15sp"
                android:background="@drawable/card_background"
                android:paddingHorizontal="16dp"
                android:inputType="number"
                android:layout_marginBottom="28dp" />

            <!-- Save Button -->
            <Button
                android:id="@+id/btnSaveProfile"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Save Changes"
                android:textColor="@color/text_white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/bg_button_orange" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>
