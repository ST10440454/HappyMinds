<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/bg_white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <ImageView
            android:id="@+id/ivSubjectIcon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_icon_orange"
            android:src="@drawable/ic_book"
            android:padding="10dp"
            android:contentDescription="Subject"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <TextView
            android:id="@+id/tvClassName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Reading &amp; Writing"
            android:textColor="@color/text_dark"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginStart="12dp"
            app:layout_constraintStart_toEndOf="@id/ivSubjectIcon"
            app:layout_constraintEnd_toStartOf="@id/btnJoin"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvClassTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="3:00 PM - 4:30 PM"
            android:textColor="@color/text_light"
            android:textSize="13sp"
            android:layout_marginTop="3dp"
            android:layout_marginStart="12dp"
            app:layout_constraintStart_toEndOf="@id/ivSubjectIcon"
            app:layout_constraintEnd_toStartOf="@id/btnJoin"
            app:layout_constraintTop_toBottomOf="@id/tvClassName" />

        <TextView
            android:id="@+id/btnJoin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/join"
            android:textColor="@color/orange_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
