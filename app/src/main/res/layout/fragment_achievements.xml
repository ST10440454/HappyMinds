<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_cream">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_orange_gradient"
        android:paddingHorizontal="20dp"
        android:paddingTop="52dp"
        android:paddingBottom="24dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_chevron_right"
            android:rotation="180"
            android:contentDescription="Back"
            android:layout_marginEnd="12dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Achievements"
            android:textColor="@color/text_white"
            android:textSize="22sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Stats summary -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp" android:layout_height="80dp" android:layout_weight="1"
                    app:cardCornerRadius="14dp" app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/bg_light_orange" android:layout_marginEnd="8dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="8" android:textSize="26sp" android:textStyle="bold"
                            android:textColor="@color/orange_primary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Earned" android:textSize="12sp" android:textColor="@color/text_medium"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp" android:layout_height="80dp" android:layout_weight="1"
                    app:cardCornerRadius="14dp" app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/bg_light_teal" android:layout_marginEnd="8dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="4" android:textSize="26sp" android:textStyle="bold"
                            android:textColor="@color/teal_primary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Locked" android:textSize="12sp" android:textColor="@color/text_medium"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp" android:layout_height="80dp" android:layout_weight="1"
                    app:cardCornerRadius="14dp" app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/icon_bg_yellow">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="3" android:textSize="26sp" android:textStyle="bold"
                            android:textColor="@color/progress_yellow"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Special" android:textSize="12sp" android:textColor="@color/text_medium"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- Earned section -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🏆 Recently Earned"
                android:textSize="17sp" android:textStyle="bold"
                android:textColor="@color/text_dark" android:layout_marginBottom="12dp"/>

            <!-- Badge row 1 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardCornerRadius="14dp" app:cardElevation="2dp"
                app:cardBackgroundColor="@color/bg_white" android:layout_marginBottom="10dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:padding="14dp">
                    <TextView android:layout_width="48dp" android:layout_height="48dp"
                        android:text="⭐" android:textSize="26sp" android:gravity="center"
                        android:background="@drawable/card_background" android:layout_marginEnd="14dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Star Learner" android:textSize="15sp" android:textStyle="bold"
                            android:textColor="@color/text_dark"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Completed 10 lessons in a row" android:textSize="13sp"
                            android:textColor="@color/text_light"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="✓" android:textSize="18sp" android:textColor="@color/teal_primary"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Badge row 2 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardCornerRadius="14dp" app:cardElevation="2dp"
                app:cardBackgroundColor="@color/bg_white" android:layout_marginBottom="10dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:padding="14dp">
                    <TextView android:layout_width="48dp" android:layout_height="48dp"
                        android:text="🔥" android:textSize="26sp" android:gravity="center"
                        android:background="@drawable/card_background" android:layout_marginEnd="14dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="7-Day Streak" android:textSize="15sp" android:textStyle="bold"
                            android:textColor="@color/text_dark"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Logged in 7 days in a row" android:textSize="13sp"
                            android:textColor="@color/text_light"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="✓" android:textSize="18sp" android:textColor="@color/teal_primary"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Badge row 3 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardCornerRadius="14dp" app:cardElevation="2dp"
                app:cardBackgroundColor="@color/bg_white" android:layout_marginBottom="24dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:padding="14dp">
                    <TextView android:layout_width="48dp" android:layout_height="48dp"
                        android:text="📚" android:textSize="26sp" android:gravity="center"
                        android:background="@drawable/card_background" android:layout_marginEnd="14dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Bookworm" android:textSize="15sp" android:textStyle="bold"
                            android:textColor="@color/text_dark"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Read 5 full lessons" android:textSize="13sp"
                            android:textColor="@color/text_light"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="✓" android:textSize="18sp" android:textColor="@color/teal_primary"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Locked section -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🔒 Locked"
                android:textSize="17sp" android:textStyle="bold"
                android:textColor="@color/text_dark" android:layout_marginBottom="12dp"/>

            <!-- Locked badge 1 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardCornerRadius="14dp" app:cardElevation="2dp"
                app:cardBackgroundColor="@color/bg_white" android:layout_marginBottom="10dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:padding="14dp"
                    android:alpha="0.5">
                    <TextView android:layout_width="48dp" android:layout_height="48dp"
                        android:text="🎯" android:textSize="26sp" android:gravity="center"
                        android:background="@drawable/card_background" android:layout_marginEnd="14dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Perfect Score" android:textSize="15sp" android:textStyle="bold"
                            android:textColor="@color/text_dark"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Get 100% on any quiz" android:textSize="13sp"
                            android:textColor="@color/text_light"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🔒" android:textSize="18sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Locked badge 2 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardCornerRadius="14dp" app:cardElevation="2dp"
                app:cardBackgroundColor="@color/bg_white" android:layout_marginBottom="10dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:padding="14dp"
                    android:alpha="0.5">
                    <TextView android:layout_width="48dp" android:layout_height="48dp"
                        android:text="🌍" android:textSize="26sp" android:gravity="center"
                        android:background="@drawable/card_background" android:layout_marginEnd="14dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="World Explorer" android:textSize="15sp" android:textStyle="bold"
                            android:textColor="@color/text_dark"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Complete all Geography lessons" android:textSize="13sp"
                            android:textColor="@color/text_light"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🔒" android:textSize="18sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
