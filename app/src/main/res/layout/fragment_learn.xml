<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_cream">

    <!-- Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/learning_center"
        android:textColor="@color/text_dark"
        android:textSize="22sp"
        android:textStyle="bold"
        android:paddingHorizontal="20dp"
        android:paddingTop="56dp"
        android:paddingBottom="16dp" />

    <!-- Search bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingBottom="16dp">

        <ImageView
            android:id="@+id/ivSearchIcon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_search"
            android:contentDescription="Search"
            app:layout_constraintStart_toStartOf="@id/etSearch"
            android:layout_marginStart="14dp"
            app:layout_constraintTop_toTopOf="@id/etSearch"
            app:layout_constraintBottom_toBottomOf="@id/etSearch" />

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_search_bar"
            android:hint="@string/search_lessons"
            android:textColorHint="@color/text_light"
            android:textSize="14sp"
            android:textColor="@color/text_dark"
            android:paddingStart="42dp"
            android:paddingEnd="16dp"
            android:inputType="text"
            android:imeOptions="actionSearch"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Filter chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="16dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:id="@+id/llFilters"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/chipAll"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="All"
                android:textSize="14sp"
                android:textColor="@color/text_white"
                android:background="@drawable/bg_chip_selected"
                android:paddingHorizontal="18dp"
                android:gravity="center"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/chipReading"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Reading"
                android:textSize="14sp"
                android:textColor="@color/text_dark"
                android:background="@drawable/bg_chip_unselected"
                android:paddingHorizontal="18dp"
                android:gravity="center"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/chipMath"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Math"
                android:textSize="14sp"
                android:textColor="@color/text_dark"
                android:background="@drawable/bg_chip_unselected"
                android:paddingHorizontal="18dp"
                android:gravity="center"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/chipScience"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Science"
                android:textSize="14sp"
                android:textColor="@color/text_dark"
                android:background="@drawable/bg_chip_unselected"
                android:paddingHorizontal="18dp"
                android:gravity="center"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/chipArts"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Arts"
                android:textSize="14sp"
                android:textColor="@color/text_dark"
                android:background="@drawable/bg_chip_unselected"
                android:paddingHorizontal="18dp"
                android:gravity="center" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Lessons list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvLessons"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="16dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false" />

</LinearLayout>
