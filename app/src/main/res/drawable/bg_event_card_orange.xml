<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/bg_light_orange" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <item android:right="0dp" android:top="0dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/orange_primary" />
            <corners android:topLeftRadius="12dp" android:bottomLeftRadius="12dp" />
            <size android:width="4dp" />
        </shape>
    </item>
</layer-list>
